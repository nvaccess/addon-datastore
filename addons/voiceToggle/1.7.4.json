	"translations": [
		{
			"language": "cs",
			"displayName": "VoiceToggle",
			"description": "Umožňuje snadné přepínání mezi předvolenými hlasy.\nDefinujte požadované hlasy v nastavení NVDA, a poté kdykoliv použijte zkratku NVDA + Alt + V pro přepnutí na následující hlas."
		},
		{
			"language": "de",
			"displayName": "Sprachumschaltung",
			"description": "Ermöglicht einfaches Umschalten zwischen vordefinierten Stimmen.\nDefinieren Sie die Stimmen in den NVDA-Einstellungen und schalten Sie dann jederzeit mit NVDA + Alt + V zur nächsten Stimme um."
		},
		{
			"language": "pt_BR",
			"displayName": "AlternarVoz",
			"description": "Permite alternar facilmente entre vozes predefinidas.\nDefina as vozes nas configurações do NVDA e, em seguida, use NVDA + Alt + V a qualquer momento para alternar para a próxima voz."
		},
		{
			"language": "sk",
			"displayName": "VoiceToggle",
			"description": "Umožňuje ľahké prepínanie medzi predvolenými hlasmi.\nDefinujte požadované hlasy v nastaveniach NVDA, a potom kedykoľvek použite skratku NVDA + Alt + V pre prepnutie na nasledujúci hlas."
		},
		{
			"language": "uk",
			"displayName": "Перемикач голосів",
			"description": "Дозволяє легко перемикатися між попередньо визначеними голосами.\nВизначте голоси у налаштуваннях NVDA, а потім використовуйте NVDA + Alt + V у будь-який час для перемикання на наступний голос."
		},
		{
			"language": "vi",
			"displayName": "VoiceToggle",
			"description": "Cho phép dễ dàng chuyển đổi giữa các giọng nói đã xác định.\nXác định giọng nói trong cấu hình NVDA, sau đó sử dụng NVDA + Alt + V bất cứ lúc nào để chuyển sang giọng nói tiếp theo."
		},
		{
			"language": "zh_CN",
			"displayName": "VoiceToggle_语音切换器",
			"description": "允许在预定义的声音之间轻松切换。\n在NVDA设置中定义语音，然后随时使用NVDA+Alt+V切换到下一个语音。"
		}
	],
