    {
      "language": "ar",
      "displayName": "تحسين إمكانية الوصول في WhatsApp Desktop",
      "description": "توفر هذه الإضافة تحسينات في إمكانية الوصول لتطبيق Web WhatsApp Desktop بما في ذلك اختصارات التنقل، وتحسينات التفاعل مع الرسائل، ودعم أفضل لقارئات الشاشة."
    },
    {
      "language": "de",
      "displayName": "Verbesserungen der Barrierefreiheit von WhatsApp Desktop",
      "description": "Bietet Verbesserungen der Barrierefreiheit für den webbasierten WhatsApp-Desktop, einschließlich Navigationsverknüpfungen, Verbesserungen der Nachrichteninteraktion und besserer Unterstützung für Bildschirmleseprogramme."
    },
    {
      "language": "en",
      "displayName": "WhatsApp Desktop accessibility enhancements",
      "description": "Provides accessibility improvements for the web-based WhatsApp Desktop, including navigation shortcuts, message interaction enhancements, and better screen reader support."
    },
    {
      "language": "es",
      "displayName": "WhatsApp Desktop accessibility enhancements",
      "description": "Proporciona mejoras de accesibilidad para la versión de escritorio de WhatsApp basada en web, incluyendo atajos de navegación, mejoras en la interacción con los mensajes y un soporte optimizado para el lector de pantalla."
    },
    {
      "language": "fi",
      "displayName": "WhatsAppin työpöytäversion saavutettavuuslaajennukset",
      "description": "Lisää WhatsAppin web-versioon pohjautuvaan sovellukseen navigointityökaluja, kuten näppäinkomentoja ja parempaa ruudunlukua."
    },
    {
      "language": "it",
      "displayName": "Migliorie di accessibilità per WhatsApp desktop",
      "description": "Fornisce miglioramenti di accessibilità per WhatsApp Desktop basata sul web, come tasti rapidi di navigazione, migliorie nell'interazione con i messaggi, e un miglior supporto allo screen reader."
    },
    {
      "language": "pt",
      "displayName": "Melhorias de acessibilidade para o WhatsApp Desktop",
      "description": "Fornece melhorias de acessibilidade para o WhatsApp Desktop baseado na web, incluindo atalhos de navegação, melhorias na interação com mensagens e melhor suporte para leitor de ecrã."
    },
    {
      "language": "ru",
      "displayName": "WhatsApp Desktop accessibility enhancements (Улучшения доступности для WhatsApp Desktop)",
      "description": "Это дополнение предоставляет улучшения доступности для веб-версии WhatsApp Desktop, предоставляя сочитания клавиш для быстрого перехода к элементам интерфейса, улучшения взаимодействия с сообщениями и улучшенную поддержку программ экранного доступа."
    },
    {
      "language": "tr",
      "displayName": "WhatsApp Masaüstü erişilebilirlik geliştirmeleri",
      "description": "Web tabanlı WhatsApp Masaüstü için dolaşım kısayolları, mesaj etkileşimi geliştirmeleri ve daha iyi ekran okuyucu desteği dahil olmak üzere erişilebilirlik iyileştirmeleri sağlar."
    },
    {
      "language": "uk",
      "displayName": "Покращення доступності WhatsApp Desktop",
      "description": "Забезпечує покращення доступності для веб-версії WhatsApp Desktop, зокрема покращення навігації, взаємодії з повідомленнями та підтримки скрінрідерів."
    }
