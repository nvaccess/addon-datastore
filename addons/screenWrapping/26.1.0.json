{
  "addonId": "screenWrapping",
  "displayName": "screen wrapping for nvda",
  "URL": "https://github.com/hamadatrichine/nvda-screen-wrapping/releases/download/v26.1/screenWrapping-26.1.nvda-addon",
  "description": "This addon brings the screen wrapping feature to nvda.\n\tWhen you press quick navigation keys such as h, b, f and others, you will be placed on the next element regardless of your current position on a webpage.\n\tIf elements are not found below your position, you will be placed at the first element of the requested type available from the beginning of the page and vice versa when you are searching upwards. this also extends to the find dialog of nvda.",
