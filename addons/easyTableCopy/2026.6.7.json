	"addonId": "easyTableCopy",
	"displayName": "Easy Table Copy",
	"URL": "https://github.com/Surveyor123/EasyTableCopy/releases/download/V2026.6.7/easyTableCopy-2026.6.7.nvda-addon",
	"description": "EasyTableCopy is an NVDA add-on designed to solve a common frustration: copying tables from the Web or lists from Windows into documents (like Word, Excel, or Outlook) without losing formatting or layout.",
	"sha256": "2a96a9b17e31bbd49f0b51494d1f632c2767a17839102be421ead456597c6955",
