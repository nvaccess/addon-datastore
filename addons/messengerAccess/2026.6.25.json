  "translations": [
    {
      "language": "vi",
      "displayName": "messengerAccess",
      "description": "If you find reading chat messages in Facebook Messenger too difficult, this add-on might be able to help you.\n\nWarning: User usage requires knowledge of userScript installation. \n\nFor this add-on, we will use userScript installed on the browser to edit the display of chat messages and forward it to the add-on. You can use shortcut keys to read the message.\nUsers can focus in the text field and press the control+[/] keyboard shortcut to keep the conversation flowing. No need to move focus around often."
    }
