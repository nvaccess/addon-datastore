  "translations": [
    {
      "language": "ar",
      "displayName": "TesseractOCR: إضافة OCR",
      "description": "Performs OCR on the selected image file, PDF, JPG, TIF, etc, or  a document through a scanner and also can get the text from an accessible PDF file.\nThe results are shown in a text file.\n\nWindows+Control+r - Performs OCR to the selected image file\nWindows+Control+w - Scans and recognize the document in the scanner\nWindows+Control+t - To get the text from an accessible PDF",
      "changelog": "Correction in image orientation since Tesseract don't do it properly.\nSome bugs were corrected."
    },
    {
